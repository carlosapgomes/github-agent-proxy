# GitHub Agent Proxy - client/agent environment example
# Copy to a local file and load it in your shell or tooling:
#   cp .env.client.example .env.client
#   source .env.client
#
# These values are for the client side only.
# GITHUB_PROXY_API_KEY must match the proxy service's PROXY_API_KEY.

GITHUB_PROXY_URL="http://localhost:8000"
GITHUB_PROXY_API_KEY="replace-with-the-same-api-key-configured-in-the-proxy"
