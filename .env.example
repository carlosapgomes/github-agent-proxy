# GitHub Agent Proxy - proxy service environment example
# Copy to .env and edit values for your local environment:
#   cp .env.example .env
# Then start the proxy with:
#   uv run uvicorn app.main:app --reload --env-file .env
#
# Important:
# - The proxy itself does not auto-load .env; Uvicorn loads it when you pass --env-file.
# - GITHUB_PRIVATE_KEY must contain the PEM content, not a file path.
# - Represent the PEM as a single quoted value with \n escapes.
# - See docs/github-app-setup.md for how to create the app and obtain these values.

PROXY_API_KEY="replace-with-random-api-key"
GITHUB_APP_ID="123456"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nreplace-this-with-your-pem-content\n-----END RSA PRIVATE KEY-----"
GITHUB_INSTALLATION_ID="12345678"

# Optional fixed Git author metadata for proxy-created commits.
# Both must be set together if you use either one.
GITHUB_COMMIT_AUTHOR_NAME=""
GITHUB_COMMIT_AUTHOR_EMAIL=""
